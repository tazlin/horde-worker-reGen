# Stage 1: Base environment setup
ARG CUDA_VERSION=12.8.1
FROM nvidia/cuda:${CUDA_VERSION}-runtime-ubuntu22.04 AS base

SHELL ["/bin/bash", "-o", "pipefail", "-c"]

ARG DEBIAN_FRONTEND=noninteractive
ENV APP_HOME=/horde-worker-reGen

RUN apt-get update && \
    apt-get install -y --no-install-recommends \
    libgl1 \
    git \
    curl \
    ca-certificates && \
    apt-get clean && \
    rm -rf /var/lib/apt/lists/*

# Install uv
COPY --from=ghcr.io/astral-sh/uv:latest /uv /uvx /bin/

# The uv cache below is a BuildKit cache mount on a different filesystem than the image layers, so uv
# cannot hardlink from it into .venv. Copy mode avoids the per-build warning and the fallback churn.
# (Inherited by the builder and final stages, covering both build-time and entrypoint uv operations.)
ENV UV_LINK_MODE=copy

# Stage 2: Install dependencies (cached layer)
FROM base AS builder

ARG GIT_BRANCH=main
ARG GIT_OWNER=Haidra-Org

RUN echo "export GIT_BRANCH=${GIT_BRANCH}" >> /env_vars && \
    echo "export GIT_OWNER=${GIT_OWNER}" >> /env_vars

WORKDIR "${APP_HOME}"

# Clone the repository
RUN git clone "https://github.com/${GIT_OWNER}/horde-worker-reGen.git" . && \
    git switch "${GIT_BRANCH}"

# Install dependencies first (better layer caching)
RUN --mount=type=cache,target=/root/.cache/uv \
    uv sync --locked --no-install-project --extra cu126

# Install the project itself
RUN --mount=type=cache,target=/root/.cache/uv \
    uv sync --locked --extra cu126

# Stage 3: Final stage
FROM builder AS final

WORKDIR "${APP_HOME}"
COPY entrypoint.sh /entrypoint.sh
COPY setup_*.sh "${APP_HOME}"
RUN chmod +x /entrypoint.sh

STOPSIGNAL SIGINT

ENTRYPOINT ["/entrypoint.sh"]
